# Copy to .env (gitignored) and fill in.
# Required to download MedGemma and ColPali weights from Hugging Face.
HF_TOKEN=hf_your_token_here

# Kaggle credentials (used by kagglehub to download the MIMIC-CXR dataset).
# Locally: paste from https://www.kaggle.com/settings -> "Create New Token".
# On Colab: prefer setting KAGGLE_USERNAME / KAGGLE_KEY in Colab Secrets instead.
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key
